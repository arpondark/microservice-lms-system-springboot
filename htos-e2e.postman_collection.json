{
  "info": {
    "name": "HTOS LMS E2E",
    "description": "End-to-end tests for AuthService, UserService, and CourseService APIs. Docker runs only Kafka, Zookeeper, and MinIO. PostgreSQL databases (lms_db, coursedb) should be running locally or in separate containers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "authBaseUrl", "value": "http://localhost:8081" },
    { "key": "userBaseUrl", "value": "http://localhost:8082" },
    { "key": "courseBaseUrl", "value": "http://localhost:8083" },
    { "key": "testName", "value": "Postman E2E User" },
    { "key": "testPassword", "value": "Pass@123" },
    { "key": "testEmail", "value": "" },
    { "key": "registeredEmail", "value": "" },
    { "key": "jwtToken", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "teacherName", "value": "Postman Teacher" },
    { "key": "teacherEmail", "value": "" },
    { "key": "teacherId", "value": "" },
    { "key": "teacherPassword", "value": "Teacher@123" },
    { "key": "adminLoginEmail", "value": "admin@gmail.com" },
    { "key": "adminLoginPassword", "value": "admin1234" },
    { "key": "adminCreatedName", "value": "Postman Admin" },
    { "key": "adminCreatedEmail", "value": "" },
    { "key": "adminCreatedPassword", "value": "Admin@123" },
    { "key": "adminCreatedRole", "value": "STUDENT" },
    { "key": "adminJwtToken", "value": "" },
    { "key": "courseId", "value": "" },
    { "key": "courseName", "value": "Advanced Spring Boot" },
    { "key": "teacherJwtToken", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('testEmail')) {",
          "  const unique = Date.now();",
          "  pm.collectionVariables.set('testEmail', `e2e_${unique}@mail.com`);",
          "}",
          "if (!pm.collectionVariables.get('teacherEmail')) {",
          "  const unique = Date.now();",
          "  pm.collectionVariables.set('teacherEmail', `teacher_${unique}@mail.com`);",
          "}",
          "if (!pm.collectionVariables.get('adminCreatedEmail')) {",
          "  const unique = Date.now();",
          "  pm.collectionVariables.set('adminCreatedEmail', `admin_${unique}@mail.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "E2E Flow",
      "item": [
        {
          "name": "1) Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{testName}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": "{{authBaseUrl}}/auth/signup"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Signup response message is correct', function () {",
                  "  pm.expect(pm.response.text()).to.eql('User Registered');",
                  "});",
                  "",
                  "pm.collectionVariables.set('registeredEmail', pm.collectionVariables.get('testEmail'));"
                ]
              }
            }
          ]
        },
        {
          "name": "2) Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registeredEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{authBaseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const token = pm.response.text().replace(/^\"|\"$/g, '');",
                  "",
                  "pm.test('Token is not empty', function () {",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Token looks like JWT', function () {",
                  "  pm.expect(token.split('.')).to.have.lengthOf(3);",
                  "});",
                  "",
                  "pm.collectionVariables.set('jwtToken', token);"
                ]
              }
            }
          ]
        },
        {
          "name": "3) Get User By Email",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{userBaseUrl}}/users/email/{{registeredEmail}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get user status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json();",
                  "",
                  "pm.test('Email matches registered email', function () {",
                  "  pm.expect(user.email).to.eql(pm.collectionVariables.get('registeredEmail'));",
                  "});",
                  "",
                  "pm.test('Password should be stored encoded', function () {",
                  "  pm.expect(user.password).to.not.eql(pm.collectionVariables.get('testPassword'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User Service Account Creation",
      "item": [
        {
          "name": "1) Login as Seeded Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminLoginEmail}}\",\n  \"password\": \"{{adminLoginPassword}}\"\n}"
            },
            "url": "{{authBaseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const token = pm.response.text().replace(/^\"|\"$/g, '');",
                  "pm.collectionVariables.set('adminJwtToken', token);"
                ]
              }
            }
          ]
        },
          {
            "name": "2) Create Teacher Account",
            "request": {
              "method": "POST",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"name\": \"{{teacherName}}\",\n  \"email\": \"{{teacherEmail}}\",\n  \"password\": \"{{teacherPassword}}\",\n  \"role\": \"TEACHER\"\n}"
              },
              "url": "{{userBaseUrl}}/users"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Teacher create status is 200', function () {",
                    "  pm.response.to.have.status(200);",
                    "});",
                    "",
                    "const user = pm.response.json();",
                    "pm.test('Teacher password is stored encoded', function () {",
                    "  pm.expect(user.password).to.not.eql(pm.collectionVariables.get('teacherPassword'));",
                    "});",
                    "",
                    "pm.collectionVariables.set('teacherId', user.id);"
                  ]
                }
              }
            ]
          },
        {
          "name": "3) Get Teacher By Email",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{userBaseUrl}}/users/email/{{teacherEmail}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get teacher status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json();",
                  "pm.test('Teacher password stays encoded', function () {",
                  "  pm.expect(user.password).to.not.eql(pm.collectionVariables.get('teacherPassword'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4) Create User via Admin Controller",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminJwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{adminCreatedName}}\",\n  \"email\": \"{{adminCreatedEmail}}\",\n  \"password\": \"{{adminCreatedPassword}}\",\n  \"role\": \"{{adminCreatedRole}}\"\n}"
            },
            "url": "{{authBaseUrl}}/admin/create"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin create status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json();",
                  "pm.test('Created user password is stored encoded', function () {",
                  "  pm.expect(user.password).to.not.eql(pm.collectionVariables.get('adminCreatedPassword'));",
                  "});",
                  "pm.test('Created user role matches requested role', function () {",
                  "  pm.expect(user.role).to.eql(pm.collectionVariables.get('adminCreatedRole'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5) Get Created User By Email",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{userBaseUrl}}/users/email/{{adminCreatedEmail}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Get created user status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const user = pm.response.json();",
                  "pm.test('Created user password stays encoded', function () {",
                  "  pm.expect(user.password).to.not.eql(pm.collectionVariables.get('adminCreatedPassword'));",
                  "});",
                  "pm.test('Created user role matches requested role', function () {",
                  "  pm.expect(user.role).to.eql(pm.collectionVariables.get('adminCreatedRole'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "6) Delete Created User via Admin Controller",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminJwtToken}}" }
            ],
            "url": "{{authBaseUrl}}/admin/delete/{{adminCreatedEmail}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin delete status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Delete response message is correct', function () {",
                  "  pm.expect(pm.response.text()).to.eql('User deleted');",
                  "});"
                ]
              }
            }
          ]
        }
       ]
     },
     {
       "name": "Course Service E2E",
       "item": [
         {
           "name": "1) Login as Teacher",
           "request": {
             "method": "POST",
             "header": [
               { "key": "Content-Type", "value": "application/json" }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"email\": \"{{teacherEmail}}\",\n  \"password\": \"{{teacherPassword}}\"\n}"
             },
             "url": "{{authBaseUrl}}/auth/login"
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "type": "text/javascript",
                 "exec": [
                   "pm.test('Teacher login status is 200', function () {",
                   "  pm.response.to.have.status(200);",
                   "});",
                   "",
                   "const token = pm.response.text().replace(/^\"|\"$/g, '');",
                   "pm.collectionVariables.set('teacherJwtToken', token);"
                 ]
               }
             }
           ]
         },
          {
            "name": "2) Create Course (Teacher)",
            "request": {
              "method": "POST",
              "header": [
                { "key": "Authorization", "value": "Bearer {{teacherJwtToken}}" }
              ],
              "body": {
                "mode": "formdata",
                "formdata": [
                  { "key": "courseName", "value": "{{courseName}}", "type": "text" },
                  { "key": "courseCode", "value": "CS101", "type": "text" },
                  { "key": "courseDescription", "value": "Learn advanced Spring Boot concepts and best practices", "type": "text" },
                  { "key": "image", "value": "", "type": "file", "disabled": true },
                  { "key": "videoUrl", "value": "https://example.com/videos/spring-boot-advanced.mp4", "type": "text" },
                  { "key": "material", "value": "", "type": "file", "disabled": true }
                ]
              },
              "url": "{{courseBaseUrl}}/courses"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Create course status is 200', function () {",
                    "  pm.response.to.have.status(200);",
                    "});",
                    "",
                    "const course = pm.response.json();",
                    "pm.test('Course has ID', function () {",
                    "  pm.expect(course.id).to.exist;",
                    "});",
                    "",
                    "pm.collectionVariables.set('courseId', course.id);"
                  ]
                }
              }
            ]
          },
          {
            "name": "3) Get All Courses",
            "request": {
              "method": "GET",
              "header": [
                { "key": "Accept", "value": "application/json" }
              ],
              "url": "{{courseBaseUrl}}/courses"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Get courses status is 200', function () {",
                    "  pm.response.to.have.status(200);",
                    "});",
                    "",
                    "const courses = pm.response.json();",
                    "pm.test('Courses list is an array', function () {",
                    "  pm.expect(courses).to.be.an('array');",
                    "});",
                    "",
                    "pm.test('At least one course exists', function () {",
                    "  pm.expect(courses.length).to.be.greaterThan(0);",
                    "});"
                  ]
                }
              }
            ]
          },
          {
            "name": "3b) Get Teacher Courses",
            "request": {
              "method": "GET",
              "header": [
                { "key": "Accept", "value": "application/json" }
              ],
              "url": "{{courseBaseUrl}}/courses/teacher/{{teacherId}}"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Get teacher courses status is 200', function () {",
                    "  pm.response.to.have.status(200);",
                    "});",
                    "",
                    "const courses = pm.response.json();",
                    "pm.test('Teacher courses list is an array', function () {",
                    "  pm.expect(courses).to.be.an('array');",
                    "});",
                    "",
                    "pm.test('Teacher has at least one course', function () {",
                    "  pm.expect(courses.length).to.be.greaterThan(0);",
                    "});"
                  ]
                }
              }
            ]
          },
         {
           "name": "4) Student Login",
           "request": {
             "method": "POST",
             "header": [
               { "key": "Content-Type", "value": "application/json" }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"email\": \"{{registeredEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
             },
             "url": "{{authBaseUrl}}/auth/login"
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "type": "text/javascript",
                 "exec": [
                   "pm.test('Student login status is 200', function () {",
                   "  pm.response.to.have.status(200);",
                   "});",
                   "",
                   "const token = pm.response.text().replace(/^\"|\"$/g, '');",
                   "pm.collectionVariables.set('jwtToken', token);"
                 ]
               }
             }
           ]
         },
         {
           "name": "5) Student Enroll in Course",
           "request": {
             "method": "POST",
             "header": [
               { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
             ],
             "url": "{{courseBaseUrl}}/courses/{{courseId}}/enroll"
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "type": "text/javascript",
                 "exec": [
                   "pm.test('Enrollment status is 200', function () {",
                   "  pm.response.to.have.status(200);",
                   "});",
                   "",
                   "const enrollment = pm.response.json();",
                   "pm.test('Enrollment has ID', function () {",
                   "  pm.expect(enrollment.id).to.exist;",
                   "});",
                   "",
                   "pm.test('Enrollment has correct student and course', function () {",
                   "  pm.expect(enrollment.studentId).to.exist;",
                   "  pm.expect(enrollment.courseId).to.exist;",
                   "});"
                 ]
               }
             }
           ]
         }
       ]
     },
     {
       "name": "Course Authorization Tests",
       "item": [
        {
          "name": "Student Cannot Create Course",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "courseName", "value": "Unauthorized Course", "type": "text" },
                { "key": "courseDescription", "value": "This should fail", "type": "text" }
              ]
            },
            "url": "{{courseBaseUrl}}/courses"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Student create course returns 500 (runtime exception)', function () {",
                  "  pm.expect(pm.response.code).to.not.eql(200);",
                  "});"
                ]
              }
            }
          ]
        }
       ]
     },
     {
       "name": "Negative Cases",
       "item": [
         {
           "name": "Login with wrong password",
           "request": {
             "method": "POST",
             "header": [
               { "key": "Content-Type", "value": "application/json" }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"email\": \"{{registeredEmail}}\",\n  \"password\": \"wrong-password\"\n}"
             },
             "url": "{{authBaseUrl}}/auth/login"
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "type": "text/javascript",
                 "exec": [
                   "pm.test('Wrong password should fail', function () {",
                   "  pm.expect(pm.response.code).to.not.eql(200);",
                   "});",
                   "",
                   "pm.test('Error mentions invalid credentials', function () {",
                   "  pm.expect(pm.response.text().toLowerCase()).to.include('invalid credentials');",
                   "});"
                 ]
               }
             }
           ]
         }
       ]
     }
  ]
}

